-- ==================== CHIKOBESO DW - FULL + MOBILE ====================

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera

local player = Players.LocalPlayer
local mouse = player:GetMouse()

local deletedObjects = {}
local highlight = nil
local deleteMode = false

local isMobile = UserInputService.TouchEnabled and not UserInputService.MouseEnabled

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = player:WaitForChild("PlayerGui")

local Frame = Instance.new("Frame")
Frame.Size = UDim2.new(0, 200, 0, 120)
Frame.Position = UDim2.new(0.5, -100, 0.5, -60)
Frame.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
Frame.Active = true
Frame.Draggable = true
Frame.Parent = ScreenGui

Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 12)

local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1, 0, 0, 30)
Title.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
Title.Text = "DW"
Title.TextColor3 = Color3.new(1,1,1)
Title.TextScaled = true
Title.Font = Enum.Font.GothamBold
Title.Parent = Frame

local DeleteBtn = Instance.new("TextButton")
DeleteBtn.Size = UDim2.new(0.9, 0, 0, 38)
DeleteBtn.Position = UDim2.new(0.05, 0, 0.35, 0)
DeleteBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
DeleteBtn.Text = "Delete Walls: OFF"
DeleteBtn.TextColor3 = Color3.new(1,1,1)
DeleteBtn.TextScaled = true
DeleteBtn.Font = Enum.Font.GothamSemibold
DeleteBtn.Parent = Frame
Instance.new("UICorner", DeleteBtn).CornerRadius = UDim.new(0, 8)

local RestoreBtn = Instance.new("TextButton")
RestoreBtn.Size = UDim2.new(0.9, 0, 0, 38)
RestoreBtn.Position = UDim2.new(0.05, 0, 0.68, 0)
RestoreBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
RestoreBtn.Text = "Restablecer (0)"
RestoreBtn.TextColor3 = Color3.new(1,1,1)
RestoreBtn.TextScaled = true
RestoreBtn.Font = Enum.Font.GothamSemibold
RestoreBtn.Parent = Frame
Instance.new("UICorner", RestoreBtn).CornerRadius = UDim.new(0, 8)

local function CanDelete(obj)
    if not obj or not obj.Parent then return false end
    if obj:IsA("Terrain") or obj.Name == "Baseplate" then return false end
    if obj.Size.X > 250 and obj.Size.Z > 250 then return false end
    if obj.Position.Y < -30 then return false end
    local char = obj:FindFirstAncestorWhichIsA("Model")
    if char and Players:GetPlayerFromCharacter(char) then return false end
    return obj:IsA("BasePart") or obj:IsA("MeshPart") or obj:IsA("UnionOperation")
end

local function CreateHighlight()
    if highlight then highlight:Destroy() end
    highlight = Instance.new("SelectionBox")
    highlight.LineThickness = 0.05
    highlight.Color3 = Color3.fromRGB(255, 60, 60)
    highlight.Transparency = 0.5
    highlight.Parent = game.CoreGui
end

-- Highlight
RunService.RenderStepped:Connect(function()
    if not deleteMode then
        if highlight then highlight.Adornee = nil end
        return
    end
    local target = mouse.Target
    if target and CanDelete(target) then
        if not highlight then CreateHighlight() end
        highlight.Adornee = target
    else
        if highlight then highlight.Adornee = nil end
    end
end)

-- ==================== BORRADO (PC + MOBILE) ====================

if isMobile then
    -- CELULAR: Solo 1 toque
    UserInputService.InputBegan:Connect(function(input, processed)
        if not deleteMode or processed then return end
        if input.UserInputType == Enum.UserInputType.Touch then
            task.wait(0.03) -- Fix para Delta y otros executors
            local target = mouse.Target
            if target and CanDelete(target) then
                table.insert(deletedObjects, {
                    object = target, 
                    parent = target.Parent, 
                    cframe = target.CFrame,
                    size = target.Size, 
                    color = target.Color, 
                    transparency = target.Transparency,
                    cancollide = target.CanCollide, 
                    anchored = target.Anchored
                })
                target.Parent = nil
                RestoreBtn.Text = "Restablecer (" .. #deletedObjects .. ")"
            end
        end
    end)
else
    -- PC: Alt + Click
    mouse.Button1Down:Connect(function()
        if not deleteMode then return end
        if not (UserInputService:IsKeyDown(Enum.KeyCode.LeftAlt) or UserInputService:IsKeyDown(Enum.KeyCode.RightAlt)) then return end
        local target = mouse.Target
        if target and CanDelete(target) then
            table.insert(deletedObjects, {
                object = target, 
                parent = target.Parent, 
                cframe = target.CFrame,
                size = target.Size, 
                color = target.Color, 
                transparency = target.Transparency,
                cancollide = target.CanCollide, 
                anchored = target.Anchored
            })
            target.Parent = nil
            RestoreBtn.Text = "Restablecer (" .. #deletedObjects .. ")"
        end
    end)
end

-- Botones
DeleteBtn.MouseButton1Click:Connect(function()
    deleteMode = not deleteMode
    DeleteBtn.Text = "Delete Walls: " .. (deleteMode and "ON" or "OFF")
    DeleteBtn.BackgroundColor3 = deleteMode and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(45, 45, 50)
end)

RestoreBtn.MouseButton1Click:Connect(function()
    if #deletedObjects > 0 then
        local last = table.remove(deletedObjects)
        if last and last.object then
            pcall(function()
                last.object.Parent = last.parent
                last.object.CFrame = last.cframe
                last.object.Size = last.size
                last.object.Color = last.color
                last.object.Transparency = last.transparency
                last.object.CanCollide = last.cancollide
                last.object.Anchored = last.anchored
            end)
        end
        RestoreBtn.Text = "Restablecer (" .. #deletedObjects .. ")"
    end
end)
